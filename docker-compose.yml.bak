services:

  # ─────────────────────────────────────────────
  # INFRASTRUCTURE
  # ─────────────────────────────────────────────

  rabbitmq:
    image: rabbitmq:3-management
    container_name: rabbitmq
    ports:
      - "5672:5672"
      - "15672:15672"   # management UI → http://localhost:15672 (guest/guest)
    healthcheck:
      test: ["CMD", "rabbitmq-diagnostics", "ping"]
      interval: 10s
      timeout: 5s
      retries: 10
    networks:
      - marketplace_network

  # ─────────────────────────────────────────────
  # ATOMIC SERVICE: ORDER (FastAPI, in-memory)
  # ─────────────────────────────────────────────

  order-service:
    build:
      context: ./backend/microservices/order_service
      dockerfile: Dockerfile
    container_name: order_service
    ports:
      - "5001:8000"
    networks:
      - marketplace_network

  # ─────────────────────────────────────────────
  # ATOMIC SERVICE: PAYMENT (Flask + MySQL)
  # ─────────────────────────────────────────────

  payment-db:
    image: mysql:8.0
    container_name: payment_db
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: payment_db
    ports:
      - "3306:3306"
    volumes:
      - payment-db-data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 10
    networks:
      - marketplace_network

  payment-service:
    build:
      context: ./backend/microservices/payment_service
      dockerfile: DockerFile
    container_name: payment_service
    ports:
      - "5004:5000"
    environment:
      - DATABASE_URL=mysql+mysqlconnector://root:root@payment-db:3306/payment_db
      - STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
    depends_on:
      payment-db:
        condition: service_healthy
    networks:
      - marketplace_network

  # ─────────────────────────────────────────────
  # ATOMIC SERVICE: DISPUTE (Flask + MySQL)
  # ─────────────────────────────────────────────

  dispute-db:
    image: mysql:8.0
    container_name: dispute_db
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: dispute
    ports:
      - "3308:3306"
    volumes:
      - dispute-db-data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 10
    networks:
      - marketplace_network

  dispute-service:
    build:
      context: ./backend/microservices/dispute_service
      dockerfile: Dockerfile
    container_name: dispute_service
    ports:
      - "5005:5000"
    environment:
      - DATABASE_URL=mysql+mysqlconnector://root:root@dispute-db:3306/dispute
    depends_on:
      dispute-db:
        condition: service_healthy
    networks:
      - marketplace_network

  # ─────────────────────────────────────────────
  # ATOMIC SERVICE: EVIDENCE (Flask + MySQL)
  # ─────────────────────────────────────────────

  evidence-db:
    image: mysql:8.0
    container_name: evidence_db
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: evidence
    ports:
      - "3309:3306"
    volumes:
      - evidence-db-data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 10
    networks:
      - marketplace_network

  evidence-service:
    build:
      context: ./backend/microservices/evidence_service
      dockerfile: DockerFile
    container_name: evidence_service
    ports:
      - "5003:5003"
    environment:
      - DB_HOST=evidence-db
      - DB_PORT=3306
      - DB_USER=root
      - DB_PASSWORD=root
      - DB_NAME=evidence
    depends_on:
      evidence-db:
        condition: service_healthy
    networks:
      - marketplace_network

  # ─────────────────────────────────────────────
  # ATOMIC SERVICE: MESSAGING (Flask + MySQL)
  # ─────────────────────────────────────────────

  messaging-db:
    image: mysql:8.0
    container_name: messaging_db
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: messaging_db
    ports:
      - "3310:3306"
    volumes:
      - messaging-db-data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 10
    networks:
      - marketplace_network

  messaging-service:
    build:
      context: ./backend/microservices/messaging_service
      dockerfile: DockerFile
    container_name: messaging_service
    ports:
      - "5007:5003"
    environment:
      - DB_URL=mysql+mysqlconnector://root:root@messaging-db:3306/messaging_db
      - RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
    depends_on:
      messaging-db:
        condition: service_healthy
      rabbitmq:
        condition: service_healthy
    networks:
      - marketplace_network

  # ─────────────────────────────────────────────
  # ATOMIC SERVICE: NOTIFICATION (Flask + MySQL + RabbitMQ consumer)
  # ─────────────────────────────────────────────

  notification-db:
    image: mysql:8.0
    container_name: notification_db
    environment:
      MYSQL_ROOT_PASSWORD: root
      MYSQL_DATABASE: notification_db
    ports:
      - "3311:3306"
    volumes:
      - notification-db-data:/var/lib/mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 10s
      timeout: 5s
      retries: 10
    networks:
      - marketplace_network

  notification-service:
    build:
      context: ./backend/microservices/notification_service
      dockerfile: Dockerfile
    container_name: notification_service
    ports:
      - "5002:5002"
    environment:
      - DB_URL=mysql+mysqlconnector://root:root@notification-db:3306/notification_db
      - RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
    depends_on:
      notification-db:
        condition: service_healthy
      rabbitmq:
        condition: service_healthy
    networks:
      - marketplace_network

  # ─────────────────────────────────────────────
  # COMPOSITE SERVICE: PLACE ORDER
  # ─────────────────────────────────────────────

  place-order-service:
    build:
      context: ./backend/compositeservices/placeOrder
      dockerfile: Dockerfile
    container_name: place_order_service
    ports:
      - "5006:5006"
    environment:
      - ORDER_SERVICE_URL=http://order-service:8000
      - PAYMENT_SERVICE_URL=http://payment-service:5000
      - LISTING_SERVICE_URL=${LISTING_SERVICE_URL}
      - MESSAGING_SERVICE_URL=http://messaging-service:5003
      - RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
    depends_on:
      rabbitmq:
        condition: service_healthy
      order-service:
        condition: service_started
      payment-service:
        condition: service_started
      messaging-service:
        condition: service_started
    networks:
      - marketplace_network

  # ─────────────────────────────────────────────
  # COMPOSITE SERVICE: RAISE DISPUTE
  # ─────────────────────────────────────────────

  raise-dispute-service:
    build:
      context: ./backend/compositeservices/raiseDispute
      dockerfile: Dockerfile
    container_name: raise_dispute_service
    ports:
      - "5010:5010"
    environment:
      - DISPUTE_SERVICE_URL=http://dispute-service:5000
      - PAYMENT_SERVICE_URL=http://payment-service:5000
      - ORDER_SERVICE_URL=http://order-service:8000
      - EVIDENCE_SERVICE_URL=http://evidence-service:5003
      - RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
    depends_on:
      rabbitmq:
        condition: service_healthy
      dispute-service:
        condition: service_started
      payment-service:
        condition: service_started
      order-service:
        condition: service_started
      evidence-service:
        condition: service_started
    networks:
      - marketplace_network

  # ─────────────────────────────────────────────
  # API GATEWAY: KONG (DB-less)
  # ─────────────────────────────────────────────

  kong:
    image: kong:3.6
    container_name: kong
    environment:
      KONG_DATABASE: "off"
      KONG_DECLARATIVE_CONFIG: /kong/declarative/kong.yml
      KONG_PROXY_ACCESS_LOG: /dev/stdout
      KONG_ADMIN_ACCESS_LOG: /dev/stdout
      KONG_PROXY_ERROR_LOG: /dev/stderr
      KONG_ADMIN_ERROR_LOG: /dev/stderr
      KONG_ADMIN_LISTEN: "0.0.0.0:8001"
    ports:
      - "8000:8000"
      - "8001:8001"
    volumes:
      - ./backend/microservices/kong.yml:/kong/declarative/kong.yml
    depends_on:
      - payment-service
      - order-service
      - dispute-service
      - messaging-service
      - notification-service
      - place-order-service
      - raise-dispute-service
    networks:
      - marketplace_network

  # ─────────────────────────────────────────────
  # FRONTEND: Vue 3 + Vite
  # ─────────────────────────────────────────────

  frontend:
    build:
      context: ./frontend
      dockerfile: Dockerfile
    container_name: frontend
    ports:
      - "5173:5173"
    environment:
      - VITE_KONG_URL=http://localhost:8000
    depends_on:
      - kong
    networks:
      - marketplace_network

# ─────────────────────────────────────────────
# VOLUMES & NETWORKS
# ─────────────────────────────────────────────

volumes:
  payment-db-data:
  dispute-db-data:
  evidence-db-data:
  messaging-db-data:
  notification-db-data:

networks:
  marketplace_network:
    driver: bridge
